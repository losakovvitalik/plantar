{
  "name": "@plantar/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Деплой React-приложений на Ubuntu-серверы без терминала",
  "author": "Vitaliy Losakov",
  "repository": {
    "type": "git",
    "url": "https://github.com/losakovvitalik/plantar.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder --publish never",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "libsodium-wrappers": "^0.7.15",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@fontsource-variable/manrope": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@plantar/config": "workspace:*",
    "@plantar/core": "workspace:*",
    "@plantar/i18n": "workspace:*",
    "@plantar/ssh": "workspace:*",
    "@plantar/storage": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.1.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.475.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.plantar.desktop",
    "productName": "Plantar",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    },
    "publish": {
      "provider": "github"
    }
  }
}
