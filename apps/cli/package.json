{
  "name": "@plantar/cli",
  "version": "0.1.0",
  "description": "Deploy web apps and Telegram bots to Ubuntu servers — Plantar CLI",
  "type": "module",
  "bin": {
    "plantar": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "node scripts/build.mjs",
    "prepublishOnly": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@plantar/i18n": "workspace:*",
    "@plantar/config": "workspace:*",
    "@plantar/core": "workspace:*",
    "@plantar/ssh": "workspace:*",
    "@plantar/storage": "workspace:*",
    "commander": "^12.1.0",
    "esbuild": "^0.28.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
